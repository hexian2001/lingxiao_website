---
import LandingLayout from '../../layouts/LandingLayout.astro';

const base = import.meta.env.BASE_URL;
const baseUrl = base.endsWith('/') ? base : `${base}/`;
const docsUrl = `${baseUrl}getting-started/introduction`;
const githubUrl = 'https://github.com/hexian2001/lingxiao-coding';
const zhUrl = `${baseUrl}`;

const stats = [
  ['Strategy', 'Leader Control'],
  ['Formation', 'DAG Orchestration'],
  ['Evidence', 'Verification Loop'],
  ['Arsenal', '100+ Tools'],
];
const capabilities = [
  ['Strategize', 'Define goals, boundaries, risks, and acceptance criteria first.'],
  ['Form Ranks', 'Order tasks via DAG — parallel where possible, blocking where needed.'],
  ['Dispatch', 'Assign specialists: research, coding, testing, review — each in its place.'],
  ['Gather Proof', 'Build, test, browser, logs, and contracts all leave verifiable traces.'],
  ['Leave Records', 'Blackboard, memory, Git, and sessions preserve every decision.'],
  ['Patrol', 'Eternal Goals advance continuously — complete and close, or surface blockers.'],
];
const architectureBranches = [
  ['TaskBoard DAG', 'Dependencies, blockers, dispatch, fix & review states'],
  ['AgentPool', 'Research, coding, testing, review experts in parallel'],
  ['ToolRegistry', 'File, Shell, Git, Browser, HTTP, MCP — all sheathed'],
];
const evidenceNodes = [
  ['SQLite', 'Session state & task trajectory'],
  ['Git / Diff', 'Changes, commits & recovery'],
  ['Artifacts', 'Builds, logs, screenshots, reports'],
];
const installMac = 'git clone https://github.com/hexian2001/lingxiao-coding.git && cd lingxiao-coding && npm install && npm run build && npm link';
const installWin = 'git clone https://github.com/hexian2001/lingxiao-coding.git && cd lingxiao-coding && npm install && npm run build && npm link';
---

<LandingLayout title="LingXiao — One Sword Cleaves the Sky" lang="en">
  <main class="home-shell">
    <div class="ink-flow-bg" aria-hidden="true">
      <div class="ink-blob ink-blob-1"></div>
      <div class="ink-blob ink-blob-2"></div>
      <div class="ink-blob ink-blob-3"></div>
    </div>
    <div class="particle-field" aria-hidden="true">
      {Array.from({ length: 16 }, (_, i) => <span class="particle" style={`--p-delay:${i * 0.8}s;--p-dur:${12 + (i % 5) * 3}s;--p-x:${(i * 37) % 100}%;`}></span>)}
    </div>

    <section class="home-hero">
      <nav class="home-nav">
        <a class="home-brand" href={baseUrl}><img src={`${baseUrl}logo.svg`} alt="LingXiao" /><span>LingXiao</span></a>
        <div class="home-links">
          <a href="#capabilities">Features</a>
          <a href="#showcase">Showcase</a>
          <a href="#architecture">Architecture</a>
          <a href="#projects">Cases</a>
          <a href={docsUrl}>Docs</a>
          <a class="lang-switch" href={zhUrl} title="中文">中文</a>
        </div>
      </nav>
      <div class="home-hero-grid">
        <div class="home-copy">
          <p class="home-kicker">AI Engineering Command · Local-First</p>
          <h1><span>LingXiao</span><small>Engineering as bone, evidence as blade</small></h1>
          <p class="home-lede">One command spawns order; a hundred tools sheathed, all evidence archived. LingXiao weaves goals, tasks, tools, and verification into a traceable local engineering fabric: define the stance, divide the blades, then close the scroll.</p>
          <div class="home-actions"><a class="home-btn primary" href={docsUrl}>Get Started</a><a class="home-btn" href="https://github.com/hexian2001/lingxiao-coding/releases" target="_blank" rel="noopener">Download v1.0.2</a><a class="home-btn" href={githubUrl} target="_blank" rel="noopener">GitHub</a></div>
          <div class="home-install" aria-label="Install command">
            <div class="install-tabs">
              <button class="install-tab active" data-cmd="mac">Install</button>
            </div>
            <div class="install-body">
              <span class="install-prompt">❯</span>
              <code class="cmd-mac">{installMac}</code>
              <code class="cmd-win" hidden>{installWin}</code>
              <button class="install-copy" aria-label="Copy command" title="Copy command">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              </button>
            </div>
          </div>
          <script is:inline>
            document.querySelectorAll('.install-tab').forEach(tab => {
              tab.addEventListener('click', () => {
                document.querySelectorAll('.install-tab').forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                const isWin = tab.dataset.cmd === 'win';
                document.querySelector('.cmd-mac').hidden = isWin;
                document.querySelector('.cmd-win').hidden = !isWin;
              });
            });
            document.querySelector('.install-copy').addEventListener('click', async (e) => {
              const codeEl = document.querySelector('.cmd-mac').hidden
                ? document.querySelector('.cmd-win')
                : document.querySelector('.cmd-mac');
              try {
                await navigator.clipboard.writeText(codeEl.textContent);
                const btn = e.currentTarget;
                const svg = btn.innerHTML;
                btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
                setTimeout(() => { btn.innerHTML = svg; }, 1500);
              } catch {}
            });
          </script>
          <div class="home-stats">{stats.map(([value,label]) => <div><strong>{value}</strong><span>{label}</span></div>)}</div>
        </div>
        <div class="home-showcase" id="showcase">
          <div class="ink-mountain" aria-hidden="true"></div>
          <figure class="shot light"><figcaption>Light · Rice Paper Ink</figcaption><img src={`${baseUrl}screenshots/lingxiao-web-light.png`} alt="LingXiao light theme WebUI" /></figure>
          <figure class="shot dark"><figcaption>Dark · Ink Night Gold</figcaption><img src={`${baseUrl}screenshots/lingxiao-web-dark.png`} alt="LingXiao dark theme WebUI" /></figure>
        </div>
      </div>
    </section>

    <section class="home-section intro reveal">
      <p class="home-kicker">Product Positioning</p>
      <h2>AI Collaboration with Method, Evidence, and Home</h2>
      <p>LingXiao doesn't chase one-off sparks of brilliance. It breaks complex delivery into executable, observable, and recoverable engineering processes. From goal to specialist分工, to evidence-based acceptance — every step leaves a trail.</p>
    </section>

    <section class="home-section reveal" id="capabilities">
      <div class="section-head"><p class="home-kicker">Six Weapons Form the Array</p><h2>From Model Intuition to Engineering Discipline</h2></div>
      <div class="cap-grid">{capabilities.map(([title,text], index) => <article class="reveal" style={`--reveal-delay:${index * 80}ms`}><b>{String(index + 1).padStart(2, '0')}</b><h3>{title}</h3><p>{text}</p></article>)}</div>
    </section>

    <section class="home-section architecture reveal" id="architecture">
      <div class="section-head"><p class="home-kicker">Architecture</p><h2>Three Fronts, One Core, A Hundred Tools, All Evidence Filed</h2></div>
      <div class="arch-topology" aria-label="LingXiao architecture diagram">
        <div class="arch-layer arch-layer-entry">
          <div class="arch-layer-label">Entry Layer</div>
          <div class="arch-entry-row">
            <div class="arch-pill"><span>WebUI</span></div>
            <div class="arch-pill"><span>TUI</span></div>
            <div class="arch-pill"><span>CLI</span></div>
          </div>
        </div>

        <div class="arch-connector arch-connector-merge" aria-hidden="true">
          <svg viewBox="0 0 300 40" preserveAspectRatio="none"><path d="M50,0 L50,16 L150,28 L150,40 M150,0 L150,28 L150,40 M250,0 L250,16 L150,28 L150,40" fill="none" stroke="currentColor" stroke-width="1.5" class="connector-line"/><circle cx="150" cy="30" r="2.5" fill="currentColor" class="connector-pulse"/></svg>
        </div>

        <div class="arch-core-node arch-node-glow">
          <div class="arch-core-pulse" aria-hidden="true"></div>
          <small>Session Core</small>
          <strong>SessionRuntime</strong>
          <span>Maintains mode, event stream, task board, tool calls, and resumable context.</span>
        </div>

        <div class="arch-connector arch-connector-line" aria-hidden="true">
          <svg viewBox="0 0 300 30" preserveAspectRatio="none"><line x1="150" y1="0" x2="150" y2="30" stroke="currentColor" stroke-width="1.5" class="connector-line"/><circle cx="150" cy="15" r="2.5" fill="currentColor" class="connector-pulse"/></svg>
        </div>

        <div class="arch-leader-node">
          <div class="arch-leader-pulse" aria-hidden="true"></div>
          <small>Central Hub</small>
          <strong>LeaderAgent</strong>
          <span>Understands goals, decomposes plans, selects roles, dispatches tasks, and accepts final delivery.</span>
        </div>

        <div class="arch-connector arch-connector-fanout" aria-hidden="true">
          <svg viewBox="0 0 300 40" preserveAspectRatio="none"><path d="M150,0 L150,12 L50,28 L50,40 M150,0 L150,12 L150,28 L150,40 M150,0 L150,12 L250,28 L250,40" fill="none" stroke="currentColor" stroke-width="1.5" class="connector-line"/><circle cx="50" cy="30" r="2.5" fill="currentColor" class="connector-pulse"/><circle cx="150" cy="30" r="2.5" fill="currentColor" class="connector-pulse"/><circle cx="250" cy="30" r="2.5" fill="currentColor" class="connector-pulse"/></svg>
        </div>

        <div class="arch-layer arch-layer-exec">
          <div class="arch-layer-label">Execution Plane</div>
          <div class="arch-exec-grid">
            {architectureBranches.map(([title, text]) => <article class="arch-exec-card"><div class="arch-card-glow" aria-hidden="true"></div><strong>{title}</strong><span>{text}</span></article>)}
          </div>
        </div>

        <div class="arch-divider" aria-hidden="true"><span>↓</span></div>

        <div class="arch-layer arch-layer-evidence">
          <div class="arch-layer-label">Evidence Layer</div>
          <div class="arch-evidence-grid">
            {evidenceNodes.map(([title, text]) => <article class="arch-evidence-card"><strong>{title}</strong><span>{text}</span></article>)}
          </div>
        </div>
      </div>
    </section>

    <section class="home-section proof reveal">
      <p class="home-kicker">Use Cases</p>
      <h2>For Long-Term, Complex, Must-Ship AI Engineering</h2>
      <div class="proof-grid"><article><h3>Product Delivery</h3><p>API contracts, frontend/backend implementation, browser verification, and docs — all in sync.</p></article><article><h3>Code Governance</h3><p>Tech debt, test gaps, migration plans, and fix tasks continuously patrolled.</p></article><article><h3>Internal Automation</h3><p>Office, PDF, MCP, Workflow, and local toolchains — unified orchestration.</p></article></div>
    </section>

    <section class="home-section showcase-projects reveal" id="projects">
      <div class="section-head"><p class="home-kicker">Proof of the Blade</p><h2>Case Studies</h2><p class="showcase-subtitle">Both projects were autonomously built by LingXiao AI — from architecture to deployment, fully AI-driven</p></div>
      <div class="showcase-grid">
        <article class="showcase-card reveal">
          <div class="showcase-screenshot">
            <img src={`${baseUrl}screenshots/showcase-tribulation.png`} alt="Lingxiao Tribulation — DAG Attack Tree Visualization" loading="lazy" />
            <div class="showcase-overlay"><span>View Repo →</span></div>
          </div>
          <div class="showcase-info">
            <div class="showcase-name"><span class="showcase-badge">劫</span> Lingxiao Tribulation</div>
            <p class="showcase-desc">LLM-driven autonomous pentest platform · DAG + Blackboard + Plan&Execute</p>
            <div class="showcase-tags"><span>FastAPI</span><span>Next.js 14</span><span>WebSocket</span></div>
            <a class="home-btn" href="https://github.com/hexian2001/lingxiao-tribulation" target="_blank" rel="noopener">GitHub</a>
          </div>
        </article>
        <article class="showcase-card reveal" style="--reveal-delay:100ms">
          <div class="showcase-screenshot">
            <img src={`${baseUrl}screenshots/showcase-inkflow.png`} alt="Ink-Flow — Agent Real-time Monitor" loading="lazy" />
            <div class="showcase-overlay"><span>View Repo →</span></div>
          </div>
          <div class="showcase-info">
            <div class="showcase-name"><span class="showcase-badge">墨</span> Ink-Flow</div>
            <p class="showcase-desc">Multi-Agent collaborative novel writing platform · Ink-Gold design language</p>
            <div class="showcase-tags"><span>Express</span><span>React 18</span><span>WebSocket</span></div>
            <a class="home-btn" href="https://github.com/hexian2001/ink-flow" target="_blank" rel="noopener">GitHub</a>
          </div>
        </article>
      </div>
    </section>

    <section class="home-cta reveal">
      <p class="home-kicker">LingXiao v1.0.2</p>
      <h2>Open the Scroll, Make Your Move, Close with Proof</h2>
      <div class="home-actions"><a class="home-btn primary" href={docsUrl}>Get Started</a><a class="home-btn" href={githubUrl} target="_blank" rel="noopener">View Repository</a></div>
    </section>
  </main>
</LandingLayout>
