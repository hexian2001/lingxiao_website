---
import LandingLayout from '../layouts/LandingLayout.astro';

const base = import.meta.env.BASE_URL;
const baseUrl = base.endsWith('/') ? base : `${base}/`;
const docsUrl = `${baseUrl}getting-started/introduction`;
const githubUrl = 'https://github.com/hexian2001/lingxiao';

const stats = [
  ['13+', '专家角色'],
  ['100+', '工具能力'],
  ['3 端', '实时同步'],
  ['DAG', '任务编排'],
];
const capabilities = [
  ['令', 'Leader 指挥内核', '拆解目标、调度专家、整合证据，把复杂工程从对话变成可执行计划。'],
  ['阵', '任务 DAG 编排', '依赖、并发、阻塞、回执与修复全部结构化，避免多 Agent 撞写。'],
  ['证', '验收闭环', '每项交付回到测试、构建、浏览器、日志和契约证据，而不是模型自述。'],
  ['器', '真实工具系统', '文件、Shell、Git、浏览器、Office、PDF、MCP 统一纳管，动作可追溯。'],
  ['图', '黑板与记忆', '契约、发现、决策与证据跨 Agent 共享，让上下文不再漂移。'],
  ['玄', 'Eternal Goal', '目标持续注入、自动巡逻推进、完成时显式收口，适合长线自主工程。'],
];
const flow = ['目标进入', '蓝图拆解', '专家并行', '证据验收', '修复收口'];
---

<LandingLayout title="凌霄剑域 · LingXiao — AI 工程指挥系统">
  <main class="home-shell">
    <section class="home-hero">
      <nav class="home-nav">
        <a class="home-brand" href={baseUrl}><img src={`${baseUrl}logo.svg`} alt="凌霄" /><span>凌霄剑域</span></a>
        <div class="home-links"><a href="#capabilities">能力</a><a href="#showcase">界面</a><a href="#architecture">架构</a><a href={docsUrl}>文档</a></div>
      </nav>
      <div class="home-hero-grid">
        <div class="home-copy">
          <p class="home-kicker">AI Engineering Command System</p>
          <h1>以工程之法，驭 AI 万象</h1>
          <p class="home-lede">凌霄不是聊天壳，而是本地优先的 AI 工程指挥系统：Leader 统筹全局，专家团并行作战，任务 DAG、契约、证据与恢复链路组成可审查的工程内核。</p>
          <div class="home-actions"><a class="home-btn primary" href={docsUrl}>进入文档</a><a class="home-btn" href={githubUrl} target="_blank" rel="noopener">GitHub</a></div>
          <div class="home-install"><span>$</span><code>npm install && npm run build && npm link</code></div>
          <div class="home-stats">{stats.map(([value,label]) => <div><strong>{value}</strong><span>{label}</span></div>)}</div>
        </div>
        <div class="home-showcase" id="showcase">
          <figure class="shot light"><figcaption>Light · 宣纸水墨</figcaption><img src={`${baseUrl}screenshots/lingxiao-web-light.png`} alt="凌霄亮色主题 WebUI" /></figure>
          <figure class="shot dark"><figcaption>Dark · 墨夜金锋</figcaption><img src={`${baseUrl}screenshots/lingxiao-web-dark.png`} alt="凌霄暗色主题 WebUI" /></figure>
        </div>
      </div>
    </section>

    <section class="home-section intro">
      <p class="home-kicker">为何需要凌霄</p>
      <h2>复杂工程不能只靠一次回答</h2>
      <p>真实项目需要规划、拆解、并行、验收、修复与追溯。凌霄把这些工程动作做成运行时协议，让 AI 能被调度、能被验证、能持续完成目标。</p>
    </section>

    <section class="home-section" id="capabilities">
      <div class="section-head"><p class="home-kicker">核心能力</p><h2>从模型能力到工程能力</h2></div>
      <div class="cap-grid">{capabilities.map(([mark,title,text]) => <article><b>{mark}</b><h3>{title}</h3><p>{text}</p></article>)}</div>
    </section>

    <section class="home-section split" id="architecture">
      <div><p class="home-kicker">运行架构</p><h2>一套内核，贯通 WebUI / TUI / CLI</h2><p>SessionRuntime 管理状态，LeaderAgent 负责指挥，TaskBoard 承载 DAG，AgentPool 并行执行，ToolRegistry 接入真实工具，SQLite 与 Git 提供可恢复轨迹。</p></div>
      <div class="flow-card">{flow.map((item, index) => <div><span>{String(index + 1).padStart(2, '0')}</span><strong>{item}</strong></div>)}</div>
    </section>

    <section class="home-section proof">
      <p class="home-kicker">适用场景</p>
      <h2>面向长期、复杂、可验收的 AI 工程</h2>
      <div class="proof-grid"><article><h3>产品交付</h3><p>接口契约、前后端实现、浏览器验收与文档同步一体推进。</p></article><article><h3>代码治理</h3><p>技术债、测试缺口、迁移计划和修复任务可持续巡逻。</p></article><article><h3>内部自动化</h3><p>Office、PDF、MCP、Workflow 和本地工具链统一编排。</p></article></div>
    </section>

    <section class="home-cta">
      <p class="home-kicker">LingXiao v0.3.9</p>
      <h2>让 AI 成为可指挥、可审查、可恢复的工程团队</h2>
      <div class="home-actions"><a class="home-btn primary" href={docsUrl}>开始使用</a><a class="home-btn" href={githubUrl} target="_blank" rel="noopener">查看仓库</a></div>
    </section>
  </main>
</LandingLayout>
