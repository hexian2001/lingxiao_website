---
import LandingLayout from '../layouts/LandingLayout.astro';

const base = import.meta.env.BASE_URL;
const baseUrl = base.endsWith('/') ? base : `${base}/`;
const docsUrl = `${baseUrl}getting-started/introduction`;
const githubUrl = 'https://github.com/hexian2001/lingxiao';

const stats = [
  ['策', 'Leader 主控'],
  ['阵', 'DAG 编排'],
  ['证', '验收闭环'],
  ['器', '百器入鞘'],
];
const capabilities = [
  ['定策', '先立目标、边界、风险与验收口径。'],
  ['布阵', '以 DAG 分明先后，让并行有序、阻塞可见。'],
  ['遣将', '按角色调度专家，研发、验证、审查各归其位。'],
  ['取证', '构建、测试、浏览器、日志与契约共同落证。'],
  ['留痕', '黑板、记忆、Git 与会话沉淀每一次决策。'],
  ['巡天', 'Eternal Goal 持续推进，完成则收卷，遇阻则明示。'],
];
const architectureBranches = [
  ['TaskBoard DAG', '依赖、阻塞、派发、修复与评估状态'],
  ['AgentPool', '研究、编码、测试、审查等专家并行执行'],
  ['ToolRegistry', '文件、Shell、Git、浏览器、HTTP、MCP 入鞘'],
];
const evidenceNodes = [
  ['SQLite', '会话状态与任务轨迹'],
  ['Git / Diff', '变更、提交与恢复'],
  ['Artifacts', '构建、日志、截图、报告'],
];
const installMac = 'curl -fsSL https://raw.githubusercontent.com/hexian2001/lingxiao/main/scripts/install.sh | sh';
const installWin = 'irm https://raw.githubusercontent.com/hexian2001/lingxiao/main/scripts/install.ps1 | iex';
---

<LandingLayout title="凌霄剑域 · LingXiao — 国风 AI 工程指挥系统">
  <main class="home-shell">
    <section class="home-hero">
      <nav class="home-nav">
        <a class="home-brand" href={baseUrl}><img src={`${baseUrl}logo.svg`} alt="凌霄" /><span>凌霄剑域</span></a>
        <div class="home-links"><a href="#capabilities">能力</a><a href="#showcase">界面</a><a href="#architecture">架构</a><a href={docsUrl}>文档</a></div>
      </nav>
      <div class="home-hero-grid">
        <div class="home-copy">
          <p class="home-kicker">AI 工程指挥 · 本地运行</p>
          <h1><span>凌霄剑域</span><small>以工程为骨，以证据为锋</small></h1>
          <p class="home-lede">一念成令，诸工有序；百器入鞘，诸证归卷。凌霄将目标、任务、工具与验收织成一条可追溯的本地工程脉络：先定势，再分锋，后收卷。</p>
          <div class="home-actions"><a class="home-btn primary" href={docsUrl}>入门文档</a><a class="home-btn" href={githubUrl} target="_blank" rel="noopener">GitHub</a></div>
          <div class="home-install" aria-label="安装命令">
            <div class="install-tabs">
              <button class="install-tab active" data-cmd="mac">macOS / Linux</button>
              <button class="install-tab" data-cmd="win">Windows</button>
            </div>
            <div class="install-body">
              <span>令</span>
              <code class="cmd-mac">{installMac}</code>
              <code class="cmd-win" hidden>{installWin}</code>
              <button class="install-copy" aria-label="复制命令" title="复制命令">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              </button>
            </div>
          </div>
          <script is:inline>
            document.querySelectorAll('.install-tab').forEach(tab => {
              tab.addEventListener('click', () => {
                document.querySelectorAll('.install-tab').forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                const isWin = tab.dataset.cmd === 'win';
                document.querySelector('.cmd-mac').hidden = isWin;
                document.querySelector('.cmd-win').hidden = !isWin;
              });
            });
            document.querySelector('.install-copy').addEventListener('click', async (e) => {
              const codeEl = document.querySelector('.cmd-mac').hidden
                ? document.querySelector('.cmd-win')
                : document.querySelector('.cmd-mac');
              try {
                await navigator.clipboard.writeText(codeEl.textContent);
                const btn = e.currentTarget;
                const svg = btn.innerHTML;
                btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
                setTimeout(() => { btn.innerHTML = svg; }, 1500);
              } catch {}
            });
          </script>
          <div class="home-stats">{stats.map(([value,label]) => <div><strong>{value}</strong><span>{label}</span></div>)}</div>
        </div>
        <div class="home-showcase" id="showcase">
          <div class="ink-mountain" aria-hidden="true"></div>
          <figure class="shot light"><figcaption>Light · 宣纸水墨</figcaption><img src={`${baseUrl}screenshots/lingxiao-web-light.png`} alt="凌霄亮色主题 WebUI" /></figure>
          <figure class="shot dark"><figcaption>Dark · 墨夜金锋</figcaption><img src={`${baseUrl}screenshots/lingxiao-web-dark.png`} alt="凌霄暗色主题 WebUI" /></figure>
        </div>
      </div>
    </section>

    <section class="home-section intro">
      <p class="home-kicker">产品定位</p>
      <h2>让 AI 协作有章法、有凭据、有归处</h2>
      <p>凌霄不追逐一次性的灵光一现，而把复杂交付拆成可执行、可观察、可恢复的工程过程。任务从目标入卷，到专家分工，再到证据验收，皆有迹可循。</p>
    </section>

    <section class="home-section" id="capabilities">
      <div class="section-head"><p class="home-kicker">六器成阵</p><h2>从模型灵性，炼成工程章法</h2></div>
      <div class="cap-grid">{capabilities.map(([title,text], index) => <article><b>{String(index + 1).padStart(2, '0')}</b><h3>{title}</h3><p>{text}</p></article>)}</div>
    </section>

    <section class="home-section architecture" id="architecture">
      <div class="section-head"><p class="home-kicker">架构</p><h2>三端入局，一核调度，百器落证</h2></div>
      <div class="arch-map" aria-label="凌霄运行架构图">
        <article class="arch-node arch-entry"><small>入口层</small><strong>WebUI · TUI · CLI</strong><span>用户目标、权限、终端和运行态从三端进入同一会话。</span></article>
        <i class="arch-arrow" aria-hidden="true">↓</i>
        <article class="arch-node arch-runtime"><small>会话内核</small><strong>SessionRuntime</strong><span>维护模式、事件流、任务板、工具调用和可恢复上下文。</span></article>
        <i class="arch-arrow" aria-hidden="true">↓</i>
        <article class="arch-node arch-leader"><small>中枢</small><strong>LeaderAgent</strong><span>理解目标、拆解计划、选择角色、派发任务并最终验收。</span></article>
        <div class="arch-branches">
          {architectureBranches.map(([title, text]) => <article class="arch-node"><small>执行面</small><strong>{title}</strong><span>{text}</span></article>)}
        </div>
        <div class="arch-evidence">
          {evidenceNodes.map(([title, text]) => <article class="arch-node"><small>证据层</small><strong>{title}</strong><span>{text}</span></article>)}
        </div>
      </div>
    </section>

    <section class="home-section proof">
      <p class="home-kicker">适用场景</p>
      <h2>面向长期、复杂、必须落地的 AI 工程</h2>
      <div class="proof-grid"><article><h3>产品交付</h3><p>接口契约、前后端实现、浏览器验收与文档同步一体推进。</p></article><article><h3>代码治理</h3><p>技术债、测试缺口、迁移计划和修复任务可持续巡逻。</p></article><article><h3>内部自动化</h3><p>Office、PDF、MCP、Workflow 与本地工具链统一编排。</p></article></div>
    </section>

    <section class="home-cta">
      <p class="home-kicker">LingXiao v1.0.0</p>
      <h2>开卷立势，收卷有证</h2>
      <div class="home-actions"><a class="home-btn primary" href={docsUrl}>开始使用</a><a class="home-btn" href={githubUrl} target="_blank" rel="noopener">查看仓库</a></div>
    </section>
  </main>
</LandingLayout>
