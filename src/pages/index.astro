---
const base = import.meta.env.BASE_URL;
const baseUrl = base.endsWith('/') ? base : base + '/';
const docsUrl = `${baseUrl}getting-started/introduction`;
---

<!doctype html>
<html lang="zh-CN" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <link rel="icon" type="image/svg+xml" href={`${baseUrl}logo.svg`} />
  <title>凌霄剑域 · LingXiao — AI 工程指挥系统</title>
  <meta name="description" content="给 AI 一个工程内核，而不只是一个对话框。专家团协同、任务 DAG 编排、全状态同步——让复杂工程可调度、可审查、可恢复。" />
  <style>
    /* ===== 设计令牌（对齐凌霄 WebUI theme.css） ===== */
    :root {
      /* — 品牌 — */
      --lx-jade-deep: #e6b84c;       /* 金箔（暗色主品牌色） */
      --lx-jade-soft: #2b2618;       /* 金箔底纹 */
      --lx-sword: #d6a84a;           /* 剑锋金 */
      --lx-cloud: rgba(230, 184, 76, 0.14);

      /* — 暗色背景层级 — */
      --lx-bg-primary: #101315;
      --lx-bg-secondary: #151a1b;
      --lx-bg-tertiary: #222a2d;
      --lx-bg-card: rgba(28, 34, 36, 0.90);
      --lx-bg-card-hover: rgba(34, 42, 45, 0.94);
      --lx-bg-input: #191e20;
      --lx-bg-code: rgba(12, 15, 16, 0.94);

      /* — 文字 — */
      --lx-fg: #eff2f1;
      --lx-fg-secondary: #c6cecc;
      --lx-fg-tertiary: #8c989a;
      --lx-fg-muted: #808a90;
      --lx-fg-dim: #555b64;

      /* — 边框 — */
      --lx-border: rgba(210, 219, 222, 0.22);
      --lx-border-muted: rgba(210, 219, 222, 0.12);
      --lx-border-strong: rgba(210, 219, 222, 0.32);
      --lx-border-brand: rgba(230, 184, 76, 0.30);

      /* — 强调色 — */
      --lx-accent-brand: var(--lx-jade-deep);
      --lx-accent-green: #a6bfca;
      --lx-accent-red: #e06b5a;
      --lx-accent-yellow: #f2c673;

      /* — 玻璃材质 — */
      --lx-glass-highlight: rgba(236, 241, 238, 0.10);
      --lx-glass-edge: inset 0 1px 0 color-mix(in srgb, var(--lx-glass-highlight) 55%, transparent);
      --lx-shadow-flat: var(--lx-glass-edge);
      --lx-shadow-card: var(--lx-glass-edge), 0 1px 2px rgba(0,0,0,0.28), 0 14px 34px rgba(0,0,0,0.30);
      --lx-shadow-floating: var(--lx-glass-edge), 0 18px 46px rgba(0,0,0,0.42);
      --lx-shadow-hero: 0 1px 2px rgba(0,0,0,0.30), 0 18px 42px rgba(0,0,0,0.22);
      --lx-ring-focus: 0 0 0 3px color-mix(in srgb, var(--lx-accent-brand) 22%, transparent);

      /* — 按钮 — */
      --lx-btn-bg: linear-gradient(135deg, #d9ded9, #bcc8c8 58%, #9fb2bc);
      --lx-btn-fg: #111719;
      --lx-btn-hover: linear-gradient(135deg, #edf1ee, #cbd5d4 58%, #afc1ca);

      /* — 动效 — */
      --lx-motion-fast: 120ms;
      --lx-motion-base: 180ms;
      --lx-motion-slow: 260ms;
      --lx-ease: cubic-bezier(0.2, 0.8, 0.2, 1);
      --lx-ease-soft: cubic-bezier(0.16, 1, 0.3, 1);

      /* — 圆角 — */
      --lx-radius-sm: 8px;
      --lx-radius: 12px;
      --lx-radius-lg: 16px;

      /* — 布局 — */
      --lx-max-w: 1120px;

      /* — 字体 — */
      --lx-font-sans: 'Inter', 'Noto Sans SC', system-ui, -apple-system, sans-serif;
      --lx-font-serif: 'Noto Serif SC', 'Songti SC', serif;
      --lx-font-mono: 'JetBrains Mono', 'Fira Code', monospace;
    }

    /* ===== Reset ===== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body {
      font-family: var(--lx-font-sans);
      background:
        linear-gradient(145deg, color-mix(in srgb, var(--lx-bg-primary) 90%, var(--lx-jade-soft)) 0%, var(--lx-bg-primary) 56%),
        var(--lx-bg-primary);
      color: var(--lx-fg);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
    }
    a { color: var(--lx-accent-green); text-decoration: none; transition: color var(--lx-motion-fast) var(--lx-ease); }
    a:hover { color: var(--lx-jade-deep); }
    img { max-width: 100%; height: auto; display: block; }
    h1, h2, h3 { font-weight: 700; line-height: 1.2; }

    /* ===== 背景祥云纹理 ===== */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 50% at 50% -10%, var(--lx-cloud) 0%, transparent 60%),
        radial-gradient(ellipse 60% 40% at 80% 100%, rgba(230, 184, 76, 0.06) 0%, transparent 50%);
      pointer-events: none;
      z-index: 0;
    }

    /* ===== 导航栏 ===== */
    .nav {
      position: sticky;
      top: 0;
      z-index: 100;
      backdrop-filter: blur(16px) saturate(140%);
      -webkit-backdrop-filter: blur(16px) saturate(140%);
      background: rgba(16, 19, 21, 0.74);
      border-bottom: 1px solid var(--lx-border-muted);
    }
    .nav-inner {
      max-width: var(--lx-max-w);
      margin: 0 auto;
      padding: 0.75rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-brand {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      font-weight: 700;
      font-size: 1.05rem;
      color: var(--lx-fg);
    }
    .nav-brand img { width: 28px; height: 28px; }
    .nav-brand .nav-brand-sub {
      font-size: 0.7rem;
      font-weight: 500;
      color: var(--lx-fg-tertiary);
      letter-spacing: 0.05em;
    }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }
    .nav-links a {
      font-size: 0.875rem;
      color: var(--lx-fg-secondary);
      transition: color var(--lx-motion-fast) var(--lx-ease);
    }
    .nav-links a:hover { color: var(--lx-fg); }
    .nav-links .nav-cta {
      padding: 0.4rem 1rem;
      border-radius: var(--lx-radius-sm);
      background: var(--lx-btn-bg);
      color: var(--lx-btn-fg);
      font-weight: 600;
      font-size: 0.8rem;
      transition: all var(--lx-motion-base) var(--lx-ease);
    }
    .nav-links .nav-cta:hover { background: var(--lx-btn-hover); color: var(--lx-btn-fg); }

    /* ===== Hero ===== */
    .hero {
      position: relative;
      z-index: 1;
      text-align: center;
      padding: 6rem 1.5rem 4rem;
    }
    .hero-badge {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--lx-jade-deep);
      background: var(--lx-cloud);
      border: 1px solid var(--lx-border-brand);
      padding: 0.35rem 1rem;
      border-radius: 100px;
      margin-bottom: 2rem;
    }
    .hero-logo {
      width: 96px;
      height: 96px;
      margin: 0 auto 2rem;
      filter: drop-shadow(0 4px 24px rgba(230, 184, 76, 0.15));
    }
    .hero h1 {
      font-family: var(--lx-font-serif);
      font-size: 3.5rem;
      font-weight: 900;
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
      background: linear-gradient(135deg, var(--lx-fg) 0%, var(--lx-jade-deep) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-tagline {
      font-size: 1.15rem;
      color: var(--lx-fg-secondary);
      max-width: 620px;
      margin: 0 auto 2.5rem;
      line-height: 1.8;
    }
    .hero-tagline .accent { color: var(--lx-jade-deep); font-weight: 600; }
    .hero-tagline .gold { color: var(--lx-accent-yellow); font-weight: 600; }
    .hero-install {
      display: inline-flex;
      align-items: center;
      gap: 0.625rem;
      background: var(--lx-bg-code);
      border: 1px solid var(--lx-border);
      border-radius: var(--lx-radius-sm);
      padding: 0.75rem 1.25rem;
      font-family: var(--lx-font-mono);
      font-size: 0.82rem;
      color: var(--lx-fg);
      margin-bottom: 2rem;
      max-width: 100%;
      overflow-x: auto;
      box-shadow: var(--lx-shadow-flat);
    }
    .hero-install .prompt { color: var(--lx-jade-deep); user-select: none; }
    .hero-install code { white-space: nowrap; }
    .hero-cta {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.75rem;
      border-radius: var(--lx-radius-sm);
      font-weight: 600;
      font-size: 0.9rem;
      transition: all var(--lx-motion-base) var(--lx-ease);
      border: 1px solid transparent;
      cursor: pointer;
    }
    .btn svg { width: 16px; height: 16px; flex-shrink: 0; }
    .btn-primary {
      background: var(--lx-btn-bg);
      color: var(--lx-btn-fg);
      box-shadow: var(--lx-shadow-card);
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      background: var(--lx-btn-hover);
      box-shadow: var(--lx-shadow-floating);
      color: var(--lx-btn-fg);
    }
    .btn-secondary {
      background: transparent;
      color: var(--lx-fg);
      border-color: var(--lx-border-strong);
    }
    .btn-secondary:hover {
      border-color: var(--lx-border-brand);
      color: var(--lx-jade-deep);
      transform: translateY(-2px);
    }

    /* ===== Section 通用 ===== */
    .section {
      position: relative;
      z-index: 1;
      max-width: var(--lx-max-w);
      margin: 0 auto;
      padding: 4rem 1.5rem;
    }
    .section-title {
      text-align: center;
      font-family: var(--lx-font-serif);
      font-size: 2.25rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: var(--lx-fg);
    }
    .section-subtitle {
      text-align: center;
      font-size: 1.05rem;
      color: var(--lx-fg-tertiary);
      margin-bottom: 3rem;
    }

    /* ===== 特性卡片 ===== */
    .feature-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 1.25rem;
    }
    .feature-card {
      background: var(--lx-bg-card);
      border: 1px solid var(--lx-border-muted);
      border-radius: var(--lx-radius);
      padding: 1.75rem;
      transition: all var(--lx-motion-slow) var(--lx-ease);
      position: relative;
      overflow: hidden;
      box-shadow: var(--lx-shadow-flat);
    }
    .feature-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--lx-jade-deep), var(--lx-accent-green));
      opacity: 0;
      transition: opacity var(--lx-motion-base) var(--lx-ease);
    }
    .feature-card:hover {
      transform: translateY(-4px);
      border-color: var(--lx-border);
      background: var(--lx-bg-card-hover);
      box-shadow: var(--lx-shadow-card);
    }
    .feature-card:hover::before { opacity: 1; }
    .feature-card .icon {
      width: 44px;
      height: 44px;
      border-radius: var(--lx-radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.25rem;
      background: var(--lx-cloud);
      color: var(--lx-jade-deep);
    }
    .feature-card .icon svg { width: 22px; height: 22px; }
    .feature-card h3 {
      font-size: 1.1rem;
      margin-bottom: 0.5rem;
      color: var(--lx-fg);
    }
    .feature-card p {
      font-size: 0.875rem;
      line-height: 1.7;
      color: var(--lx-fg-tertiary);
    }

    /* ===== 展示区 ===== */
    .showcase-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 3rem;
      align-items: center;
    }
    .showcase-image {
      border-radius: var(--lx-radius);
      overflow: hidden;
      border: 1px solid var(--lx-border);
      box-shadow: var(--lx-shadow-floating);
    }
    .showcase-text h3 {
      font-family: var(--lx-font-serif);
      font-size: 1.6rem;
      margin-bottom: 1rem;
      color: var(--lx-fg);
    }
    .showcase-text p {
      font-size: 0.95rem;
      line-height: 1.7;
      color: var(--lx-fg-tertiary);
      margin-bottom: 1.25rem;
    }
    .showcase-text ul { list-style: none; }
    .showcase-text li {
      padding: 0.4rem 0;
      font-size: 0.9rem;
      color: var(--lx-fg-secondary);
      display: flex;
      align-items: center;
      gap: 0.625rem;
    }
    .showcase-text li::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--lx-jade-deep);
      flex-shrink: 0;
    }

    /* ===== 架构图 ===== */
    .arch-flow {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0;
    }
    .arch-layer {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }
    .arch-layer-label {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--lx-fg-dim);
      padding: 0.25rem 0.75rem;
      border-radius: 4px;
      background: var(--lx-bg-secondary);
    }
    .arch-nodes {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.75rem;
    }
    .arch-node {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.625rem 1.125rem;
      border-radius: var(--lx-radius-sm);
      font-size: 0.85rem;
      font-weight: 500;
      border: 1px solid var(--lx-border-muted);
      background: var(--lx-bg-card);
      color: var(--lx-fg);
      transition: all var(--lx-motion-base) var(--lx-ease);
      box-shadow: var(--lx-shadow-flat);
    }
    .arch-node svg { width: 18px; height: 18px; flex-shrink: 0; opacity: 0.8; }
    .arch-node:hover {
      border-color: var(--lx-border-brand);
      box-shadow: 0 2px 16px rgba(230, 184, 76, 0.08);
      transform: translateY(-2px);
    }
    .arch-node-entry { border-color: var(--lx-border-strong); }
    .arch-node-entry svg { color: var(--lx-jade-deep); }
    .arch-node-core { border-color: var(--lx-border-brand); }
    .arch-node-core svg { color: var(--lx-accent-green); }
    .arch-node-leader {
      border-color: var(--lx-border-brand);
      background: linear-gradient(135deg, var(--lx-bg-card), rgba(230, 184, 76, 0.06));
      font-weight: 600;
    }
    .arch-node-leader svg { color: var(--lx-jade-deep); }
    .arch-node-exec svg { color: var(--lx-accent-green); }
    .arch-node-worker {
      font-size: 0.78rem;
      padding: 0.5rem 0.875rem;
      border-style: dashed;
      color: var(--lx-fg-muted);
    }
    .arch-node-storage svg { color: var(--lx-fg-muted); }
    .arch-arrow {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0.5rem 0;
    }
    .arch-arrow svg { width: 20px; height: 20px; color: var(--lx-border-strong); }

    /* ===== 对比表 ===== */
    .comparison-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
      border-radius: var(--lx-radius);
      overflow: hidden;
      border: 1px solid var(--lx-border-muted);
      box-shadow: var(--lx-shadow-flat);
    }
    .comparison-table th, .comparison-table td {
      padding: 0.875rem 1.125rem;
      text-align: left;
      border-bottom: 1px solid var(--lx-border-muted);
    }
    .comparison-table thead th {
      font-weight: 700;
      color: var(--lx-fg);
      background: var(--lx-bg-secondary);
    }
    .comparison-table thead th.highlight {
      color: var(--lx-jade-deep);
    }
    .comparison-table tbody tr:last-child td { border-bottom: none; }
    .comparison-table tbody tr { transition: background var(--lx-motion-fast) var(--lx-ease); }
    .comparison-table tbody tr:hover { background: rgba(210, 219, 222, 0.04); }
    .comparison-table td { color: var(--lx-fg-tertiary); }
    .comparison-table .check { color: var(--lx-accent-green); font-weight: 600; }
    .comparison-table .cross { color: var(--lx-fg-dim); }

    /* ===== Footer ===== */
    .footer {
      position: relative;
      z-index: 1;
      border-top: 1px solid var(--lx-border-muted);
      background: var(--lx-bg-secondary);
      padding: 2.5rem 1.5rem;
    }
    .footer-content {
      max-width: var(--lx-max-w);
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1.5rem;
      align-items: center;
    }
    .footer-brand {
      display: flex;
      align-items: center;
      gap: 0.625rem;
    }
    .footer-brand img { width: 28px; height: 28px; }
    .footer-brand span { font-weight: 600; color: var(--lx-fg); font-size: 0.9rem; }
    .footer-links { display: flex; gap: 1.25rem; flex-wrap: wrap; }
    .footer-links a { font-size: 0.85rem; color: var(--lx-fg-tertiary); }
    .footer-links a:hover { color: var(--lx-jade-deep); }
    .footer-copy {
      width: 100%;
      text-align: center;
      margin-top: 1rem;
      font-size: 0.8rem;
      color: var(--lx-fg-dim);
    }

    /* ===== 响应式 ===== */
    @media (max-width: 768px) {
      .hero { padding: 4rem 1.25rem 3rem; }
      .hero h1 { font-size: 2.25rem; }
      .hero-tagline { font-size: 1rem; }
      .hero-logo { width: 72px; height: 72px; }
      .section { padding: 3rem 1.25rem; }
      .section-title { font-size: 1.6rem; }
      .feature-grid { grid-template-columns: 1fr; }
      .showcase-grid { grid-template-columns: 1fr; gap: 1.5rem; }
      .comparison-table { font-size: 0.8rem; }
      .comparison-table th, .comparison-table td { padding: 0.5rem 0.625rem; }
      .nav-links { gap: 1rem; }
      .nav-links a:not(.nav-cta) { display: none; }
    }
  </style>
</head>
<body>
  <!-- 导航 -->
  <nav class="nav">
    <div class="nav-inner">
      <a href={baseUrl} class="nav-brand">
        <img src={`${baseUrl}logo.svg`} alt="凌霄" />
        <span>凌霄剑域</span>
        <span class="nav-brand-sub">LingXiao</span>
      </a>
      <div class="nav-links">
        <a href={docsUrl}>文档</a>
        <a href="https://github.com/hexian2001/lingxiao" target="_blank" rel="noopener">GitHub</a>
        <a href={`${baseUrl}reference/changelog`}>更新日志</a>
        <a href={docsUrl} class="nav-cta">快速上手</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-badge">AI Engineering Orchestration Kernel</div>
    <img src={`${baseUrl}logo.svg`} alt="凌霄 Logo" class="hero-logo" />
    <h1>凌霄剑域</h1>
    <p class="hero-tagline">
      给 AI 一个工程内核，而不只是一个对话框。<br/>
      <span class="accent">专家团</span>协同、<span class="accent">任务 DAG</span>编排、<span class="accent">全状态同步</span>——<br/>
      让复杂工程<span class="gold">可调度、可审查、可恢复</span>。
    </p>
    <div class="hero-install">
      <span class="prompt">$</span>
      <code>git clone https://github.com/hexian2001/lingxiao.git && npm install && npm run build && npm link</code>
    </div>
    <div class="hero-cta">
      <a href={docsUrl} class="btn btn-primary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        快速上手
      </a>
      <a href="https://github.com/hexian2001/lingxiao" class="btn btn-secondary" target="_blank" rel="noopener">
